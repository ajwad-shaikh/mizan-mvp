# Mizan environment variables (names only — never commit real values)

# --- Model execution ---
# Model mode: "fixture" (deterministic, default; used by tests and the offline demo)
# or "openai" (real OpenAI-compatible provider).
MIZAN_MODEL_MODE=fixture
# OpenAI-compatible provider (only read when MIZAN_MODEL_MODE=openai). Server-only.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MIZAN_MODEL=gpt-4o-mini
# Server-enforced provider controls.
MIZAN_MODEL_TIMEOUT_MS=30000
MIZAN_MODEL_MAX_OUTPUT_TOKENS=4000

# --- Engagement resource controls ---
# Requests allowed per source IP in a fixed one-minute window.
MIZAN_RATE_LIMIT_PER_MINUTE=5
# Hard server ceiling; a user cannot request a higher engagement budget.
MIZAN_MAX_ENGAGEMENT_BUDGET_USD=5

# --- GitHub publication (server-only; never exposed to the browser) ---
# Personal access token with permission to open issues on the target public repo.
GITHUB_TOKEN=
# Comma-separated owner/repo entries. Publication is blocked unless the submitted
# repository is explicitly listed here (for example: ajwad-shaikh/mizan-mvp).
MIZAN_GITHUB_REPOSITORY_ALLOWLIST=

# --- Convex (optional) ---
# The app runs on an in-memory store by default. To use Convex, run `npx convex dev`
# and set the deployment URL below.
NEXT_PUBLIC_CONVEX_URL=
# Server-only shared secret. Set the same value in Convex deployment env.
MIZAN_CONVEX_SERVER_SECRET=
